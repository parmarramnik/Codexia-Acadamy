# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy this file to .env and fill in real values.
# ==============================================================================

# Application Settings
APP_NAME=Codexia Academy
DEBUG=False

# Database (PostgreSQL for Production, SQLite for Local Dev)
# SQLite: sqlite:///./ai_lms.db
# PostgreSQL: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT Authentication
JWT_SECRET_KEY=your-secure-random-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (Comma-separated list of allowed frontend origins)
CORS_ORIGINS=https://codexia-acadamy.vercel.app,http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=10

# Gemini AI Key
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Frontend URL (For Email Verification & Reset Password Links)
FRONTEND_URL=https://codexia-acadamy.vercel.app

# SMTP Email Configurations (Optional for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@codexia.com
